            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation CreateFamily { createFamily(path: \\\"{{familyParentPath}}\\\", key: \\\"TA-OMEGA\\\", published: true, input: { code: \\\"TA-OMEGA\\\", name: \\\"Omega\\\", launchYear: 2027, launchPeriod: \\\"sep\\\", workingTitle: \\\"Omega Working Title\\\", description: \\\"Sample family created through GraphQL\\\" }) { success message output { id fullpath code name } } }\"\n}"
            },
            "url": {
              "raw": "https://theo.digital-transformers.it/pimcore-graphql-webservices/ExampleProductHierarchyGraphQL?apikey={{apikey}}",
              "protocol": "https",

      "item": [
        {
          "name": "Get Alpha Family",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetAlphaFamily { getFamily(fullpath: \\\"{{alphaFamilyPath}}\\\") { id key fullpath published code name launchYear launchPeriod workingTitle description } }\"\n}"
            },
            "url": {
              "raw": "https://theo.digital-transformers.it/pimcore-graphql-webservices/ExampleProductHierarchyGraphQL?apikey={{apikey}}",
              "protocol": "https",
              "host": [
                "theo",
                "digital-transformers",
                "it"
              ],
              "path": [
                "pimcore-graphql-webservices",
                "ExampleProductHierarchyGraphQL"
              ],
              "query": [
                {
                  "key": "apikey",
                  "value": "{{apikey}}"
                }
              ]
            },
            "description": "Reads one imported family by full path."
          }
        },
        {
          "name": "Get Alpha Model",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetAlphaModel { getModel(fullpath: \\\"{{alphaModelPath}}\\\") { id key fullpath code name frameBaseCode seriesCode material description } }\"\n}"
            },
            "url": {
              "raw": "https://theo.digital-transformers.it/pimcore-graphql-webservices/ExampleProductHierarchyGraphQL?apikey={{apikey}}",
              "protocol": "https",
              "host": [
                "theo",
                "digital-transformers",
                "it"
              ],
              "path": [
                "pimcore-graphql-webservices",
                "ExampleProductHierarchyGraphQL"
              ],
              "query": [
                {
                  "key": "apikey",
                  "value": "{{apikey}}"
                }
              ]
            },
            "description": "Reads one imported model by full path."
          }
        },
        {
          "name": "Get Alpha Frame",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query GetAlphaFrame { getFrame(fullpath: \\\"{{alphaFramePath}}\\\") { id key fullpath code name mainColorCode seriesCode ecomFileName exchangeCode artBase { ... on object_model { id key fullpath code name } } } }\"\n}"
            },
            "url": {
              "raw": "https://theo.digital-transformers.it/pimcore-graphql-webservices/ExampleProductHierarchyGraphQL?apikey={{apikey}}",
              "protocol": "https",
              "host": [
                "theo",
                "digital-transformers",
                "it"
              ],
              "path": [
                "pimcore-graphql-webservices",
                "ExampleProductHierarchyGraphQL"
              ],
              "query": [
                {
                  "key": "apikey",
                  "value": "{{apikey}}"
                }
              ]
            },
            "description": "Reads one imported frame and follows the artBase relation."
          }
        },
        {
          "name": "List Families",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"query ListFamilies { getFamilyListing(first: 10) { edges { node { id key fullpath code name launchYear launchPeriod } } } }\"\n}"
            },
            "url": {
              "raw": "https://theo.digital-transformers.it/pimcore-graphql-webservices/ExampleProductHierarchyGraphQL?apikey={{apikey}}",
              "protocol": "https",
              "host": [
                "theo",
                "digital-transformers",
                "it"
              ],
              "path": [
                "pimcore-graphql-webservices",
                "ExampleProductHierarchyGraphQL"
              ],
              "query": [
                {
                  "key": "apikey",
                  "value": "{{apikey}}"
                }
              ]
            },
            "description": "Example export-style query using a listing operation."
          }
        }
      ]
